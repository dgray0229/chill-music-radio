{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
        "NPM_CONFIG_CACHE": "/tmp/npm-cache"
      },
      "cache": {
        "disabled": true
      }
    }
  },
  "submit": {
    "production": {}
  }
}
